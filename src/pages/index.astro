---
import Base from "../layouts/Base.astro";
---
<Base>
  <section class="hero">
    <h1>Technology That Delivers</h1>
    <p>
      NoviForge provides expert IT consulting in API Management, Identity &amp; Access Management,
      cloud-native infrastructure, and enterprise software development.
    </p>
    <a href="/expertise" class="btn">Explore our expertise</a>
  </section>

  <section class="section">
    <h2 class="section-title">What we do</h2>
    <p class="section-subtitle">We help organisations build reliable, secure, and scalable IT systems.</p>
    <div class="card-grid">
      <div class="card">
        <div class="card-icon">⚙️</div>
        <h3>API Management</h3>
        <p>Design, secure, and govern APIs at scale using modern gateway patterns and tooling.</p>
      </div>
      <div class="card">
        <div class="card-icon">🔐</div>
        <h3>Identity &amp; Access</h3>
        <p>Implement robust IAM solutions with Keycloak — SSO, OAuth 2.0, and fine-grained authorisation.</p>
      </div>
      <div class="card">
        <div class="card-icon">☸️</div>
        <h3>Kubernetes</h3>
        <p>Container orchestration, high-availability clusters, and cloud-native deployment pipelines.</p>
      </div>
    </div>
  </section>
</Base>
